# Neon / Postgres database
DATABASE_URL=postgresql://user:password@host.neon.tech/leadsense?sslmode=require&channel_binding=require

# Auth.js
AUTH_SECRET=replace-with-random-base64-32
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# OpenAI (server-side only)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5-mini

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENCRYPTION_KEY=replace-with-different-random-32-plus-character-secret

# Permanent file storage (Cloudflare R2 / S3-compatible)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=leadsense-files
R2_PUBLIC_URL=

# Permanent file storage alternative (Cloudinary - no card friendly)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe subscriptions
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
